# copy to terraform.tfvars (git-ignored) and fill in
snowflake_organization = "MYORG"
snowflake_account      = "TBAYTEL"
private_key_path       = "~/.ssh/svc_terraform_rsa_key.p8"

environments = ["DEV", "TEST", "PROD"]

tbaytel_ip_ranges      = ["203.0.113.0/24"] # real Tbaytel ranges
in516ht_ip_ranges      = ["89.212.52.137/32"]
azure_private_link_ids = [] # from SYSTEM$GET_PRIVATELINK_AUTHORIZED_ENDPOINTS()
azure_tenant_id        = ""
adls_allowed_locations = ["azure://tbaytelstorage.blob.core.windows.net/bronze/"]

# lockout-guarded activations - keep false until verified (see 4_security.tf)
activate_network_policy = false
activate_auth_policies  = false
